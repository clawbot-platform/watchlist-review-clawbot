
### `.env.example`

```dotenv
# .env.example

# Application
APP_ENV=dev
LOG_LEVEL=info

# Worker runtime
WATCHLIST_REVIEW_HTTP_ADDR=:8090
WATCHLIST_REVIEW_WORKER_ID=watchlist-review-worker-local
WATCHLIST_REVIEW_DEFAULT_TENANT=test-tenant

# Clawbot platform dependencies
CLAWBOT_SERVER_BASE_URL=http://localhost:8080
CLAWBOT_SERVER_TIMEOUT=10s

CLAWBOT_IDENTITY_BASE_URL=http://localhost:8081
CLAWBOT_IDENTITY_TIMEOUT=10s

CLAWMEM_BASE_URL=http://localhost:8180
CLAWMEM_TIMEOUT=5s

# Retrieval / RAG
RAG_ENABLED=false
RAG_KNOWLEDGE_MCP_BASE_URL=
RAG_IDENTITY_MCP_BASE_URL=
RAG_MEMORY_MCP_BASE_URL=
RAG_CONTROL_MCP_BASE_URL=
QDRANT_URL=
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Inference / models
INFERENCE_BASE_URL=http://ai-precision:11434
INFERENCE_TIMEOUT=60s

PRIMARY_MODEL_ID=granite-3.3-8b
GUARDRAIL_MODEL_ID=granite-guardian-3.3-8b
HELPER_MODEL_ID=granite-4-3b

# Review behavior
REVIEW_MODE=deterministic
ENABLE_GUARDRAIL=false
ENABLE_MEMORY=false
ENABLE_RAG=false
ENABLE_MCP_TOOLS=false

# Policy and output defaults
REQUIRE_HUMAN_REVIEW=true
DEFAULT_DECISION_ON_AMBIGUITY=investigate_next_step
MAX_RETRIEVED_PASSAGES=6
MAX_ANALYST_NOTE_TOKENS=800

# Local fixtures
FIXTURE_DIR=./test/fixtures
OUTPUT_DIR=./tmp/output